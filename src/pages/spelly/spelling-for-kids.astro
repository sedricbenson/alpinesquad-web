---
import SpellyLayout from '../../layouts/SpellyLayout.astro';
import AppStoreButton from '../../components/AppStoreButton.astro';

const title = 'Spelling Games for Kids — Free, No Ads, Family-Friendly | Spelly';
const description =
  'A free spelling game your kids will actually want to play. Picture-based learning, two game modes, daily challenges, 23 categories. No ads, no accounts, every word reviewed for safety. iPhone and iPad.';
const appStoreUrl = 'https://apps.apple.com/app/id6757465281';
---

<SpellyLayout {title} {description}>
  <section class="s-hero">
    <div class="s-hero-bg" aria-hidden="true"><div class="s-hero-glow"></div></div>
    <div class="container s-hero-inner">
      <p class="s-eyebrow">For kids &amp; families</p>
      <h1>Spelling games kids<br /><span class="s-hero-accent">actually</span> want to play.</h1>
      <p class="s-lede">
        Two modes. Thousands of words. Daily streaks. No ads, no accounts, every word reviewed for
        safety. Made by an indie dev who got tired of bloated kids' apps.
      </p>
      <div class="s-hero-cta">
        <AppStoreButton href={appStoreUrl} label="Download Spelly on the App Store" />
      </div>
    </div>
  </section>

  <section class="s-section">
    <div class="container">
      <h2 class="s-h2">What parents love</h2>
      <p class="s-section-lede">A spelling app you don't have to worry about handing to your kid.</p>
      <div class="s-feature-grid">
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg></div>
          <h4>Zero ads</h4>
          <p>No interstitials. No "watch a video for a coin." No tracking, no data collection. Ever.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
          <h4>Every word reviewed</h4>
          <p>Each word in every category passes a safety check. No surprises.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"></path><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"></path><path d="M10.71 5.05A16 16 0 0 1 22.58 9"></path><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg></div>
          <h4>Works offline</h4>
          <p>No accounts, no logins. Just open and play. Great for car rides and waiting rooms.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg></div>
          <h4>Right level for every kid</h4>
          <p>Easy (ages 6–10), Medium (11–15), Hard (16+ and SAT-grade). Grow with the app.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg></div>
          <h4>Achievements &amp; streaks</h4>
          <p>Coins, levels, daily challenges. The good kind of dopamine — earned by spelling words right.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg></div>
          <h4>iPhone &amp; iPad</h4>
          <p>Universal app. Light and dark mode. Looks great on every device in the family.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="s-section-alt">
    <div class="container">
      <h2 class="s-h2">Two modes, one app</h2>
      <div class="s-modes-grid">
        <div class="s-mode-card s-mode-a">
          <div class="s-mode-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="M21 15l-5-5L5 21"></path></svg></div>
          <h3>Picture Spell</h3>
          <p>See a picture, pick the right spelling. No timer. Great for younger kids and new readers building confidence.</p>
        </div>
        <div class="s-mode-card s-mode-b">
          <div class="s-mode-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg></div>
          <h3>Word Blitz</h3>
          <p>Tap correctly-spelled words before they disappear. Arcade-style energy for kids who like a challenge.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="s-final">
    <div class="container-narrow">
      <h2>Free. Forever.</h2>
      <p>Optional Pro tier unlocks every category and removes the lives system. Otherwise, the whole game is free.</p>
      <AppStoreButton href={appStoreUrl} label="Download Spelly on the App Store" />
    </div>
  </section>
</SpellyLayout>
