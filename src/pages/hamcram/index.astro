---
import AppShell from '../../layouts/AppShell.astro';
import AppStoreButton from '../../components/AppStoreButton.astro';
import { appStoreUrl, APP_IDS, breadcrumbList } from '../../lib/seo';

/**
 * HamCram — marketing page. Copy sourced from ham-cram/fastlane/metadata.
 *
 * Maintenance contract:
 *   - Price change → search "$9.99"
 *   - New question pool → search "Technician (2026–2030)"
 */

const title = 'HamCram — Ham Radio Exam Prep for iPhone & iPad | Pass Your FCC License Test';
const description =
  'Pass your FCC amateur radio exam the first time. HamCram drills the real NCVEC question pools — Technician and General — with flashcards, quizzes, and full 35-question practice exams. $9.99 once, no ads, no subscriptions.';

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://alpinesquad.com';
const appUrlClean = appStoreUrl(APP_IDS.hamCram);
const appUrlCta = appStoreUrl(APP_IDS.hamCram, 'web-hamcram');

const faqs = [
  {
    q: 'Which license exams does HamCram cover?',
    a: 'Technician (2026–2030 pool) and General (2023–2027 pool). Both are the complete, current NCVEC question pools — every question, every answer, every figure — parsed straight from the official source, so nothing on test day is a surprise.',
  },
  {
    q: 'Are these the real exam questions?',
    a: 'Yes. FCC amateur radio exams are built from published NCVEC question pools, and HamCram uses exactly those pools. The questions you drill are the questions you can be asked.',
  },
  {
    q: 'How do practice exams work?',
    a: 'A full 35-question simulation drawn the same way the real exam is, scored just like the real thing — pass at 26. Quizzes come in 10, 25, 50, or 100-question sizes with instant feedback when you want shorter sessions.',
  },
  {
    q: 'Does it sync between devices?',
    a: 'Yes — progress is CloudKit-synced across your devices, and multiple profiles are supported, so two people can study for different licenses on a shared iPad.',
  },
  {
    q: 'Is there a subscription?',
    a: 'No. HamCram is $9.99 once. No ads, no subscription, no in-app purchases nagging you mid-study.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MobileApplication',
      name: 'Ham Radio Exam Prep: HamCram',
      operatingSystem: 'iOS',
      applicationCategory: 'EducationApplication',
      applicationSubCategory: 'Exam Preparation',
      description,
      url: appUrlClean,
      image: `${site}/images/hamcram-icon.png`,
      offers: {
        '@type': 'Offer',
        price: '9.99',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
      },
      publisher: { '@type': 'Organization', name: 'Alpine Squad', url: site },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    breadcrumbList(site, [
      { name: 'Alpine Squad', path: '/' },
      { name: 'HamCram', path: '/hamcram' },
    ]),
  ],
};
---

<AppShell
  {title}
  {description}
  {schema}
  appName="HamCram"
  appHref="/hamcram"
  appId={APP_IDS.hamCram}
  appStoreUrl={appStoreUrl(APP_IDS.hamCram, 'web-hamcram-nav')}
  accent="#E8842A"
  accentPop="#F4A259"
  accentDeep="#C05F0E"
  privacyPath="/hamcram/privacy"
  termsPath="/hamcram/terms"
  contactEmail="support@alpinesquad.com"
>
  <!-- HERO ----------------------------------------------------------- -->
  <section class="s-hero">
    <div class="s-hero-bg" aria-hidden="true"><div class="s-hero-glow"></div></div>
    <div class="container s-hero-inner">
      <img class="s-hero-icon" src="/images/hamcram-icon.png" alt="HamCram app icon" width="84" height="84" />
      <p class="s-eyebrow">HamCram · iPhone &amp; iPad</p>
      <h1>Pass your ham radio exam, <span class="s-hero-accent">the first time</span>.</h1>
      <p class="s-lede">
        Drill the exact NCVEC question pools the real FCC exam is built from — Technician and
        General. Flashcards, quizzes, and full practice exams scored just like test day.
      </p>
      <div class="s-hero-cta">
        <AppStoreButton href={appUrlCta} label="Download HamCram on the App Store" />
        <p class="s-hero-claims">$9.99 once · No ads · No subscription</p>
      </div>

      <div class="s-stat-strip">
        <div class="s-stat"><span class="s-stat-value"><span class="accent">2</span></span><span class="s-stat-label">Complete license pools</span></div>
        <div class="s-stat"><span class="s-stat-value"><span class="accent">35</span></span><span class="s-stat-label">Question exam simulation</span></div>
        <div class="s-stat"><span class="s-stat-value"><span class="accent">26</span></span><span class="s-stat-label">To pass — just like the real thing</span></div>
        <div class="s-stat"><span class="s-stat-value"><span class="accent">0</span></span><span class="s-stat-label">Ads or subscriptions</span></div>
      </div>
    </div>
  </section>

  <!-- WHY ------------------------------------------------------------- -->
  <section class="s-section">
    <div class="container">
      <h2 class="s-h2">Study the questions you'll actually be asked.</h2>
      <p class="s-section-lede">
        FCC exams are built from published question pools. HamCram gives you exactly those pools —
        so every minute of studying counts toward test day.
      </p>
      <div class="s-feature-grid">
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div>
          <h4>Real questions</h4>
          <p>The complete, current NCVEC pools — Technician (2026–2030) and General (2023–2027) — every question, answer, and figure.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg></div>
          <h4>Learn mode</h4>
          <p>Walk through questions with the correct answer shown first — build recognition before you test yourself.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"></rect><line x1="8" y1="10" x2="16" y2="10"></line><line x1="8" y1="14" x2="13" y2="14"></line></svg></div>
          <h4>Flashcards</h4>
          <p>Flip through any pool at your own pace. Mark what you know; focus on what you don't.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
          <h4>Quizzes with instant feedback</h4>
          <p>10, 25, 50, or 100 questions — see what you got wrong the moment you answer, with a score at the end.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div>
          <h4>Full practice exams</h4>
          <p>A 35-question simulation scored exactly like the real thing — pass at 26. Know you're ready before you book the session.</p>
        </div>
        <div class="s-feature">
          <div class="s-feature-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
          <h4>Multi-profile + iCloud sync</h4>
          <p>Progress syncs across your devices via CloudKit, and multiple profiles mean the whole family can study on one iPad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING ---------------------------------------------------------- -->
  <section class="s-section-alt">
    <div class="container-narrow">
      <p class="eyebrow" style="color: var(--s-accent-deep)">Pricing</p>
      <h2 class="s-h2">Pay once. Study until you pass.</h2>
      <p class="s-price">$9.99</p>
      <p class="s-price-note">
        One-time purchase — a fraction of an exam-session retake fee. No ads interrupting your
        study, no subscription, nothing else to buy.
      </p>
    </div>
  </section>

  <!-- FAQ --------------------------------------------------------------- -->
  <section class="s-faq" id="faq">
    <div class="container-narrow">
      <p class="eyebrow" style="color: var(--s-accent-deep)">Frequently asked</p>
      <h2 class="s-h2">The short answers.</h2>
      {faqs.map((f) => (
        <details class="s-faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA ---------------------------------------------------------- -->
  <section class="s-final">
    <div class="container-narrow">
      <h2>Your callsign is waiting.</h2>
      <p>Study the real pools, pass the first time, get on the air.</p>
      <AppStoreButton href={appUrlCta} label="Download HamCram on the App Store" />
    </div>
  </section>
</AppShell>
