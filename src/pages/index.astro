---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppStoreButton from '../components/AppStoreButton.astro';
import { appStoreUrl, APP_IDS } from '../lib/seo';

const title = 'Alpine Squad — privacy-first iOS apps';
const description = 'Privacy-first iOS apps that teach. No accounts, no tracking, no subscriptions — just useful, ad-free software.';

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://alpinesquad.com';

// @graph links the brand entity to the apps it publishes — helps search
// engines understand Alpine Squad and its app catalog as one connected entity.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${site}/#org`,
      name: 'Alpine Squad',
      url: site,
      logo: `${site}/images/alpinesquad-icon.png`,
      email: 'support@alpinesquad.com',
      founder: { '@type': 'Person', name: 'Sedric Benson' },
      description,
    },
    {
      '@type': 'MobileApplication',
      name: 'Bible Blitz',
      applicationCategory: 'EducationApplication',
      operatingSystem: 'iOS',
      url: 'https://apps.apple.com/app/id6771674002',
      publisher: { '@id': `${site}/#org` },
      offers: { '@type': 'Offer', price: '0.00', priceCurrency: 'USD' },
    },
    {
      '@type': 'MobileApplication',
      name: 'Spelly',
      applicationCategory: 'EducationApplication',
      operatingSystem: 'iOS',
      url: 'https://apps.apple.com/app/id6757465281',
      publisher: { '@id': `${site}/#org` },
      offers: { '@type': 'Offer', price: '0.00', priceCurrency: 'USD' },
    },
  ],
};

const apps = [
  {
    name: 'Bible Blitz',
    tagline: 'Bible trivia that teaches Scripture.',
    description:
      '10-question rounds across KJV, NKJV & NIV. Miss one and it reveals the verse and context — so every quiz doubles as a quick study.',
    icon: '/images/bibleblitz-icon.png',
    href: '/bible-blitz',
    appStore: appStoreUrl(APP_IDS.bibleBlitz, 'web-home-bibleblitz'),
    tags: ['Education', 'Free'],
    accent: '#1FA968',
  },
  {
    name: 'Spelly',
    tagline: 'Two spelling games in one.',
    description:
      'Picture Spell to learn by sight, Word Blitz to race the clock. 14,000+ words across 23 categories — for kids, families & English learners.',
    icon: '/images/spelly-icon.png',
    href: '/spelly',
    appStore: appStoreUrl(APP_IDS.spelly, 'web-home-spelly'),
    tags: ['Word game', 'Free'],
    accent: '#6c5bcb',
  },
];
---

<BaseLayout {title} {description} {schema} ogImage="/images/alpinesquad-og.png" themeColor="#0A0F0C">
  <!-- NAV -------------------------------------------------------------- -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">⛰</span>
        <span class="brand-name">Alpine Squad</span>
      </a>
      <a href="#apps" class="nav-link">Apps</a>
    </div>
  </header>

  <!-- HERO ------------------------------------------------------------- -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"><div class="hero-glow"></div></div>
    <div class="container hero-inner">
      <h1>Privacy-first apps that<br /><span class="accent-text">actually teach</span>.</h1>
      <p class="lede">
        No accounts. No tracking. No subscriptions. Just well-crafted iOS apps that teach you
        something real and respect your time.
      </p>
      <p class="hero-meta">Two apps live today — more on the way.</p>
    </div>
  </section>

  <!-- APPS ------------------------------------------------------------- -->
  <section class="apps-section" id="apps">
    <div class="container">
      <h2 class="section-title">The apps</h2>
      <div class="apps-grid">
        {apps.map((app) => (
          <article class="app-card" style={`--card-accent: ${app.accent}`}>
            <div class="app-head">
              <img class="app-icon" src={app.icon} alt={`${app.name} app icon`} width="60" height="60" loading="lazy" />
              <div>
                <h3>{app.name}</h3>
                <p class="app-tagline">{app.tagline}</p>
              </div>
            </div>
            <p class="app-desc">{app.description}</p>
            <div class="app-tags">
              {app.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="app-actions">
              <a href={app.href} class="app-link">Learn more →</a>
              <span class="app-store-wrap">
                <AppStoreButton href={app.appStore} label={`Get ${app.name} on the App Store`} />
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER ----------------------------------------------------------- -->
  <footer class="footer">
    <div class="container footer-inner">
      <div>
        <span class="brand brand-footer">
          <span class="brand-mark" aria-hidden="true">⛰</span>
          <span class="brand-name">Alpine Squad</span>
        </span>
        <p class="footer-tag">Privacy-first iOS apps that teach.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <a href="mailto:support@alpinesquad.com">Contact</a>
      </nav>
    </div>
    <div class="container footer-bottom"><small>© 2026</small></div>
  </footer>
</BaseLayout>

<style>
  /* NAV (dark, sticky) ---------------------------------------------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 15, 12, 0.72);
    backdrop-filter: saturate(150%) blur(16px);
    -webkit-backdrop-filter: saturate(150%) blur(16px);
    border-bottom: 1px solid var(--border-on-dark);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink-on-dark);
    font-weight: 600;
    font-size: 16px;
  }
  .brand-mark { font-size: 18px; }
  .nav-link { color: var(--ink-on-dark-soft); font-size: 14px; font-weight: 500; }
  .nav-link:hover { color: var(--ink-on-dark); }

  /* HERO (dark) ----------------------------------------------------- */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--bg-dark);
    color: var(--ink-on-dark);
    padding: 104px 0 112px;
    text-align: center;
  }
  @media (max-width: 720px) {
    .hero { padding: 72px 0 80px; }
  }
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    height: 110%;
    background: radial-gradient(circle at center, rgba(31, 169, 104, 0.30) 0%, transparent 60%);
    filter: blur(48px);
  }
  .hero-inner { position: relative; max-width: 760px; }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 7.4vw, 80px);
    line-height: 1.03;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: var(--ink-on-dark);
    margin-bottom: 26px;
    text-wrap: balance;
  }
  .accent-text {
    font-style: italic;
    background: linear-gradient(135deg, var(--accent-pop) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lede {
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink-on-dark-soft);
    max-width: 52ch;
    margin: 0 auto 20px;
  }
  .hero-meta {
    font-size: 14px;
    letter-spacing: 0.3px;
    color: var(--ink-on-dark-muted);
  }

  /* APPS ------------------------------------------------------------ */
  .apps-section { padding: 80px 0 96px; background: var(--bg); }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(26px, 3vw, 34px);
    margin-bottom: 28px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 22px;
  }
  .app-card {
    position: relative;
    padding: 30px;
    border-radius: var(--r-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }
  .app-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px color-mix(in srgb, var(--card-accent) 16%, transparent),
      var(--shadow-sm);
    border-color: color-mix(in srgb, var(--card-accent) 30%, var(--border));
  }
  .app-head { display: flex; align-items: center; gap: 16px; }
  .app-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    box-shadow: 0 4px 14px rgba(14, 20, 19, 0.14);
    flex-shrink: 0;
  }
  .app-card h3 {
    font-family: var(--serif);
    font-size: 23px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
  }
  .app-tagline { color: var(--ink); font-weight: 500; font-size: 15px; margin-top: 3px; }
  .app-desc { color: var(--ink-soft); font-size: 15.5px; line-height: 1.6; flex: 1; }
  .app-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag {
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.2px;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 10%, transparent);
    padding: 4px 11px;
    border-radius: var(--r-pill);
  }
  .app-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  /* Whole card → "Learn more"; the stretched ::after makes the card clickable. */
  .app-link {
    position: static;
    color: var(--card-accent);
    font-weight: 600;
    font-size: 15px;
  }
  .app-link::after { content: ''; position: absolute; inset: 0; }
  /* App Store button sits above the stretched link so it stays separately clickable. */
  .app-store-wrap { position: relative; z-index: 1; }

  /* FOOTER (dark) --------------------------------------------------- */
  .footer {
    background: var(--bg-dark);
    color: var(--ink-on-dark-soft);
    padding: 48px 0 28px;
    border-top: 1px solid var(--border-on-dark);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 28px;
  }
  .brand-footer { color: var(--ink-on-dark); }
  .footer-tag { margin-top: 8px; font-size: 14px; color: var(--ink-on-dark-muted); }
  .footer-nav { display: flex; gap: 24px; font-size: 14px; }
  .footer-nav a { color: var(--ink-on-dark-soft); }
  .footer-nav a:hover { color: var(--ink-on-dark); }
  .footer-bottom {
    padding-top: 20px;
    border-top: 1px solid var(--border-on-dark);
    color: var(--ink-on-dark-muted);
    font-size: 12.5px;
  }
</style>
