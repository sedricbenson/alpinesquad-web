---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Bible Blitz — Bible trivia that teaches Scripture | iPhone & iPad';
const description = 'Test your Bible knowledge in 10-question rounds. Every wrong answer reveals the verse and context. No subscription. No ads. Privacy-first.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Bible Blitz',
  operatingSystem: 'iOS',
  applicationCategory: 'EducationApplication',
  applicationSubCategory: 'Bible Trivia',
  offers: {
    '@type': 'Offer',
    price: '0.00',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Alpine Squad',
    url: 'https://alpinesquad.com',
  },
  url: 'https://apps.apple.com/app/bible-blitz/id6771674002',
  description,
};

const appStoreUrl = 'https://apps.apple.com/app/bible-blitz/id6771674002';
---

<BaseLayout {title} {description} {schema} ogImage="/images/bibleblitz-og.png" theme="auto">
  <!-- ============================================================
       NAV
       ============================================================ -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand">
        <span class="brand-mark">⛰</span>
        <span class="brand-name">Alpine Squad</span>
      </a>
      <a href={appStoreUrl} class="nav-cta" rel="noopener">
        Get on App Store
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </header>

  <!-- ============================================================
       HERO — dark, gradient glow, real icon, phone mockup
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow hero-glow-green"></div>
      <div class="hero-glow hero-glow-gold"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-icon">
          <img src="/images/bibleblitz-icon.png" alt="Bible Blitz app icon" width="92" height="92" />
        </div>
        <p class="eyebrow eyebrow-on-dark">Bible Blitz · iPhone & iPad</p>
        <h1>
          Bible trivia<br/>
          that <span class="hero-accent">teaches</span> you<br/>
          Scripture.
        </h1>
        <p class="hero-lede">
          Test your Bible knowledge in 10-question rounds. Every wrong answer
          reveals the verse and the context — so each quiz is a quick Bible
          study, not just a test.
        </p>
        <div class="hero-cta">
          <a href={appStoreUrl} class="appstore-pill" rel="noopener" aria-label="Download Bible Blitz on the App Store">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            <span class="appstore-stack">
              <span class="appstore-small">Download on the</span>
              <span class="appstore-big">App Store</span>
            </span>
          </a>
          <div class="trust-row">
            <span class="trust-dot"></span>
            <span>Free · No ads · No subscription</span>
          </div>
        </div>
      </div>

      <!-- Phone mockup — when /images/bibleblitz-hero-screen.png exists, it
           gets dropped into .phone-screen. Until then, a faithful CSS
           rendering of the home screen so the hero never looks broken. -->
      <div class="hero-mock reveal" aria-hidden="true">
        <div class="phone-shell">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img class="phone-shot" src="/images/bibleblitz-hero-screen.png" alt="" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <div class="phone-screen-fallback" style="display:none">
              <div class="fb-status">9:41</div>
              <div class="fb-greeting">
                <div>
                  <div style="font-size:22px; font-weight:600">Good morning</div>
                  <div style="font-size:13px; color:#8B9292; margin-top:2px">🔥 7 day streak</div>
                </div>
              </div>
              <button class="fb-play">
                <strong>Play</strong>
                <span>10 questions · ~2 min</span>
              </button>
              <div class="fb-rows">
                <div class="fb-row"><span>☀️</span><div><b>Today's Challenge</b><span>5 questions · 2× XP bonus</span></div><span class="fb-chev">›</span></div>
                <div class="fb-row"><span>📚</span><div><b>Categories</b><span>Pick a Bible topic to focus on</span></div><span class="fb-chev">›</span></div>
                <div class="fb-row"><span>📖</span><div><b>Memorize</b><span>Learn verses by heart, step by step</span></div><span class="fb-chev">›</span></div>
                <div class="fb-row"><span>⏱</span><div><b>Timed Blitz</b><span>Beat the clock on rapid-fire questions</span></div><span class="fb-lock">🔒</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="phone-shadow" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST STRIP
       ============================================================ -->
  <section class="strip">
    <div class="container strip-inner">
      <div class="strip-item"><b>10</b><span>categories of hand-curated questions</span></div>
      <div class="strip-divider"></div>
      <div class="strip-item"><b>3</b><span>translations: KJV · NKJV · NIV</span></div>
      <div class="strip-divider"></div>
      <div class="strip-item"><b>$4.99</b><span>one-time premium · no subscription</span></div>
      <div class="strip-divider"></div>
      <div class="strip-item"><b>0</b><span>ads, trackers, or accounts</span></div>
    </div>
  </section>

  <!-- ============================================================
       BIG STATEMENT — the why
       ============================================================ -->
  <section class="statement">
    <div class="container-narrow statement-inner reveal">
      <p class="eyebrow">The premise</p>
      <h2>
        Most Bible apps make you <em>read</em>.<br/>
        Bible Blitz makes you <span class="accent-text">recall</span>.
      </h2>
      <p class="statement-body">
        Recall is the proven way to actually retain Scripture. Hand-curated
        questions, the verse and context revealed after every answer, and a
        daily challenge that gives you a reason to come back.
      </p>
      <p class="quote">
        "A wrong answer isn't a failure. It's a verse you now know."
      </p>
    </div>
  </section>

  <!-- ============================================================
       FEATURE SHOWCASE — alternating split sections
       ============================================================ -->
  <section class="feature-split">
    <div class="container feature-row reveal">
      <div class="feature-copy">
        <p class="eyebrow">Every answer teaches</p>
        <h3>The verse comes <span class="accent-text">with</span> the answer.</h3>
        <p>
          Get one wrong? You see the verse, the reference, and a quick
          explanation. The "miss" turns into a verse you now know.
        </p>
        <ul class="feature-bullets">
          <li>✓ Verse + reference revealed after every answer</li>
          <li>✓ One-sentence context, not a sermon</li>
          <li>✓ Same UX whether you got it right or wrong</li>
        </ul>
      </div>
      <div class="feature-art">
        <div class="phone-shell phone-small">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img class="phone-shot" src="/images/bibleblitz-quiz-answered.png" alt="Quiz answered screen with verse context" onerror="this.style.opacity='0'" />
          </div>
        </div>
      </div>
    </div>

    <div class="container feature-row feature-row-reverse reveal">
      <div class="feature-copy">
        <p class="eyebrow">Daily streak</p>
        <h3>A 2-minute habit that <span class="accent-text">sticks</span>.</h3>
        <p>
          A daily challenge with a 2× XP bonus, a streak counter, and a
          milestone celebration every 7, 14, 30 days. Built so opening it
          tomorrow feels easier than skipping.
        </p>
        <ul class="feature-bullets">
          <li>✓ Daily Challenge with double-XP bonus</li>
          <li>✓ Streak protection (Premium)</li>
          <li>✓ Milestone share cards for Instagram</li>
        </ul>
      </div>
      <div class="feature-art">
        <div class="phone-shell phone-small">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img class="phone-shot" src="/images/bibleblitz-results.png" alt="Quiz results screen" onerror="this.style.opacity='0'" />
          </div>
        </div>
      </div>
    </div>

    <div class="container feature-row reveal">
      <div class="feature-copy">
        <p class="eyebrow">Verse memory</p>
        <h3>Three steps to <span class="accent-text">memorize</span> any verse.</h3>
        <p>
          Read → Fill the Blanks → Recite. Fuzzy-matched so a typo doesn't
          punish you. Built-in support for KJV, NKJV, and NIV.
        </p>
        <ul class="feature-bullets">
          <li>✓ Read with key-word emphasis</li>
          <li>✓ Word-bank fill-in puzzle</li>
          <li>✓ Recite with forgiving fuzzy matching</li>
        </ul>
      </div>
      <div class="feature-art">
        <div class="phone-shell phone-small">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img class="phone-shot" src="/images/bibleblitz-memorize.png" alt="Verse memorization screen" onerror="this.style.opacity='0'" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRIVACY CARD — dark, distinct
       ============================================================ -->
  <section class="privacy">
    <div class="container privacy-card reveal">
      <div class="privacy-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <h2>Your Bible study isn't <em>data</em>.</h2>
      <p>
        Bible Blitz collects nothing. No accounts. No tracking. No analytics. No
        ads. Your name, scores, streaks, and premium status live only on your
        phone — we don't have a server that receives them, because we never
        built one.
      </p>
      <div class="privacy-pillars">
        <div><span>🔒</span><b>Local-only data</b><p>Everything's on your device. Period.</p></div>
        <div><span>🚫</span><b>No tracking</b><p>No SDKs. No analytics pixels. Nothing.</p></div>
        <div><span>⛔</span><b>No accounts</b><p>No email, no password. Just download and play.</p></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRICING — dark gradient card
       ============================================================ -->
  <section class="pricing">
    <div class="container pricing-inner reveal">
      <p class="eyebrow">Premium</p>
      <h2>One price. <span class="accent-text">One time.</span> Forever.</h2>
      <div class="pricing-card">
        <div class="pricing-tier">
          <div class="tier-name">Bible Blitz Premium</div>
          <div class="tier-price"><span class="dollar">$</span><span class="amount">4.99</span></div>
          <div class="tier-sub">one-time purchase · no subscription · no ads</div>
        </div>
        <ul class="pricing-features">
          <li><span class="check">✓</span><b>Smart Review</b> — spaced-repetition learning</li>
          <li><span class="check">✓</span><b>Timed Blitz</b> — 30-second speed rounds</li>
          <li><span class="check">✓</span><b>All 10 categories</b> — Acts, Epistles, Revelation, People, Geography</li>
          <li><span class="check">✓</span><b>Streak protection</b> — keep your run on days you slip</li>
          <li><span class="check">✓</span><b>Support a solo developer</b> building privacy-first apps</li>
        </ul>
        <a href={appStoreUrl} class="pricing-cta" rel="noopener">
          Download free, upgrade when you love it
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <p class="pricing-trust">Quick Play, Daily Challenge, Verse Memory, 5 categories, all themes, full streak system — <b>free forever</b>.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHO IT'S FOR
       ============================================================ -->
  <section class="who">
    <div class="container">
      <p class="eyebrow" style="text-align:center">Who it's for</p>
      <h2 class="who-title">Built for the people who actually open it daily.</h2>
      <div class="who-grid">
        <div class="who-card"><span>🌅</span><b>Personal devotional time</b><p>Two minutes a day, every day.</p></div>
        <div class="who-card"><span>👨‍👩‍👧</span><b>Family Bible study</b><p>Pass the phone, take turns answering.</p></div>
        <div class="who-card"><span>🎤</span><b>Sunday school icebreakers</b><p>Drop the phone on the table.</p></div>
        <div class="who-card"><span>🏫</span><b>Youth group game night</b><p>Built-in competition.</p></div>
        <div class="who-card"><span>📚</span><b>Homeschool morning circle</b><p>Five minutes during morning routines.</p></div>
        <div class="who-card"><span>✝️</span><b>Anyone who wants more</b><p>Know your Bible better than yesterday.</p></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA — bold dark band
       ============================================================ -->
  <section class="final-cta">
    <div class="final-bg" aria-hidden="true">
      <div class="hero-glow hero-glow-green"></div>
    </div>
    <div class="container-narrow final-inner reveal">
      <h2>Ready to test what you actually <em>know</em>?</h2>
      <p>Free to play. $4.99 lifetime for premium. iPhone and iPad.</p>
      <a href={appStoreUrl} class="appstore-pill appstore-pill-large" rel="noopener">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
        </svg>
        <span class="appstore-stack">
          <span class="appstore-small">Download on the</span>
          <span class="appstore-big">App Store</span>
        </span>
      </a>
    </div>
  </section>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">⛰</span>
        <div>
          <p class="footer-name">Alpine Squad</p>
          <p class="footer-micro">Privacy-first apps · built solo · Anacortes, WA</p>
        </div>
      </div>
      <nav class="footer-nav">
        <a href="https://sedricbenson.github.io/disclosures/bibleblitz/privacy.html">Privacy</a>
        <a href="https://sedricbenson.github.io/disclosures/bibleblitz/terms.html">Terms</a>
        <a href="mailto:support@alpinesquad.com">Support</a>
        <a href="/">Other apps</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ============================================================
     NAV
     ============================================================ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(251, 247, 238, 0.72);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .brand-mark { font-size: 22px; }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink);
    background: var(--bg-elevated);
    padding: 9px 16px;
    border-radius: var(--r-pill);
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--border);
    transition: all 0.15s;
  }
  .nav-cta:hover { background: var(--bg-deep); color: var(--ink); text-decoration: none; transform: translateY(-1px); }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    position: relative;
    background: var(--bg-dark);
    color: var(--ink-on-dark);
    overflow: hidden;
    padding: 88px 0 120px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.5;
  }
  .hero-glow-green {
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    top: -200px;
    left: -200px;
  }
  .hero-glow-gold {
    background: radial-gradient(circle, var(--gold) 0%, transparent 70%);
    bottom: -300px;
    right: -200px;
    opacity: 0.3;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(244, 241, 234, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 241, 234, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at center, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at center, black 30%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .hero-inner { grid-template-columns: 1fr; gap: 56px; text-align: center; }
    .hero-mock { order: -1; }
    .hero-cta { justify-content: center; }
    .trust-row { justify-content: center; }
  }

  .hero-icon {
    margin-bottom: 28px;
    display: inline-block;
  }
  .hero-icon img {
    width: 92px;
    height: 92px;
    border-radius: 22px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), 0 2px 6px rgba(0, 0, 0, 0.3);
  }
  @media (max-width: 880px) {
    .hero-icon img { width: 76px; height: 76px; border-radius: 18px; }
  }

  .hero-text .eyebrow {
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 7.5vw, 84px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--ink-on-dark);
    margin-bottom: 28px;
  }
  .hero-accent {
    font-style: italic;
    background: linear-gradient(135deg, var(--accent-pop) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: var(--accent-pop);
  }
  .accent-text {
    color: var(--accent-warm);
    font-style: italic;
  }
  .hero-lede {
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.55;
    color: var(--ink-on-dark-soft);
    max-width: 560px;
    margin-bottom: 40px;
  }
  @media (max-width: 880px) {
    .hero-lede { margin-left: auto; margin-right: auto; }
  }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .trust-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ink-on-dark-muted);
  }
  .trust-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-pop);
    box-shadow: 0 0 8px var(--accent-pop);
  }

  /* App Store pill button */
  .appstore-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(180deg, #1a1a1a 0%, #000 100%);
    color: #fff;
    padding: 12px 20px;
    border-radius: var(--r-md);
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .appstore-pill:hover {
    transform: translateY(-2px);
    text-decoration: none;
    color: #fff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }
  .appstore-stack {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    align-items: flex-start;
  }
  .appstore-small {
    font-size: 10.5px;
    font-weight: 400;
    opacity: 0.85;
    letter-spacing: 0.5px;
  }
  .appstore-big {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .appstore-pill-large { padding: 14px 24px; }
  .appstore-pill-large .appstore-big { font-size: 20px; }

  /* Phone mockup — iOS device frame */
  .hero-mock {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .phone-shell {
    position: relative;
    width: 320px;
    aspect-ratio: 9 / 19.5;
    background: linear-gradient(180deg, #1a1d24 0%, #0a0d12 100%);
    border-radius: 44px;
    padding: 6px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      var(--shadow-hero);
  }
  .phone-small { width: 260px; }
  .phone-notch {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 26px;
    background: #000;
    border-radius: 100px;
    z-index: 2;
  }
  .phone-screen {
    position: relative;
    background: var(--bg-elevated);
    color: var(--ink);
    height: 100%;
    border-radius: 38px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .phone-shot {
    width: 100%;
