---
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * Bible Blitz — marketing page.
 *
 * Design intent: minimal, premium-indie. The job of this page is to
 * convert the click into an App Store visit and to rank for Bible-trivia
 * queries. The App Store listing already shows 10 screenshots, so this
 * page leans on TEXT (good for SEO) over a long screenshot tour.
 *
 * Maintenance contract — when you update the app:
 *   - Price change → search for "$4.99" (one place in copy, one in schema)
 *   - New translation → search for "KJV · NKJV · NIV"
 *   - New hero screenshot → drop new PNG at /images/bibleblitz-hero-screen.png
 *   - New FAQ → add an entry to the `faqs` array below
 * That's it. Everything else is structural.
 */

const title = 'Bible Blitz — Bible trivia that teaches Scripture | iPhone & iPad';
const description = 'Free Bible trivia app for iPhone and iPad. 10-question rounds across KJV, NKJV, and NIV. Every wrong answer reveals the verse and context — quiz becomes study. No ads, no tracking, no subscription.';
const appStoreUrl = 'https://apps.apple.com/app/bible-blitz/id6771674002';

const faqs = [
  {
    q: 'Is Bible Blitz free?',
    a: 'Yes — the core game is free. You get unlimited 10-question rounds, daily challenges, and the verse-of-the-day across KJV, NKJV, and NIV translations. A one-time $4.99 premium unlock adds Timed Blitz mode and Smart Review (which surfaces questions you previously missed). There is no subscription.',
  },
  {
    q: 'Which Bible translations are supported?',
    a: 'King James Version (KJV), New King James Version (NKJV), and New International Version (NIV). You can switch translations in Settings at any time — the verses shown in question explanations update to match.',
  },
  {
    q: 'Does Bible Blitz work offline?',
    a: 'Yes. All question content and verse data ships with the app. You do not need an internet connection to play, and the app does not phone home while you do.',
  },
  {
    q: 'Does it require an account?',
    a: 'No. There is no signup, no email, no login. Your progress, streak, and stats are stored on your device.',
  },
  {
    q: 'Are there ads?',
    a: 'No ads, no tracking pixels, no third-party analytics SDKs. The business model is a single $4.99 in-app purchase, not your attention.',
  },
  {
    q: 'What devices are supported?',
    a: 'iPhone and iPad on iOS 17 and later. The app uses native SwiftUI and is optimized for both screen sizes.',
  },
  {
    q: 'Who makes Bible Blitz?',
    a: 'Bible Blitz is built by Alpine Squad, an independent iOS studio. We build small, focused apps and ship updates quickly based on user feedback.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MobileApplication',
      name: 'Bible Blitz',
      operatingSystem: 'iOS 17+',
      applicationCategory: 'EducationApplication',
      applicationSubCategory: 'Bible Trivia',
      description,
      url: appStoreUrl,
      offers: {
        '@type': 'Offer',
        price: '0.00',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
      },
      publisher: {
        '@type': 'Organization',
        name: 'Alpine Squad',
        url: 'https://alpinesquad.com',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout {title} {description} {schema} ogImage="/images/bibleblitz-og.png" theme="auto">
  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">⛰</span>
        <span class="brand-name">Alpine Squad</span>
      </a>
      <a href={appStoreUrl} class="nav-cta" rel="noopener">Get on App Store</a>
    </div>
  </header>

  <!-- HERO ----------------------------------------------------------- -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-text">
        <img class="hero-icon" src="/images/bibleblitz-icon.png" alt="Bible Blitz app icon" width="84" height="84" />
        <p class="eyebrow eyebrow-on-dark">Bible Blitz · iPhone &amp; iPad</p>
        <h1>Bible trivia that <span class="hero-accent">teaches</span> you Scripture.</h1>
        <p class="hero-lede">
          10-question rounds across KJV, NKJV, and NIV. Every wrong answer reveals the verse
          and the context — so each quiz is a quick Bible study, not just a test.
        </p>
        <div class="hero-cta">
          <a href={appStoreUrl} class="appstore-btn" rel="noopener" aria-label="Download Bible Blitz on the App Store">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c0-2.05 1.68-3.04 1.76-3.09-.96-1.4-2.45-1.6-2.98-1.62-1.27-.13-2.48.75-3.12.75-.65 0-1.65-.74-2.72-.72-1.39.02-2.69.81-3.41 2.06-1.46 2.53-.37 6.26 1.04 8.31.69 1 1.5 2.13 2.57 2.09 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.68.64 1.11-.02 1.81-1.02 2.49-2.02.78-1.15 1.1-2.27 1.12-2.33-.02-.01-2.14-.82-2.16-3.27zM15.02 5.97c.56-.69.94-1.63.84-2.59-.81.04-1.81.54-2.39 1.22-.52.6-.98 1.57-.86 2.49.91.07 1.84-.46 2.41-1.12z"/></svg>
            <span>
              <small>Download on the</small>
              <strong>App Store</strong>
            </span>
          </a>
          <p class="hero-claims">No ads · No tracking · No subscription</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PREMISE -------------------------------------------------------- -->
  <section class="premise">
    <div class="container-narrow">
      <p class="eyebrow">The premise</p>
      <p class="premise-line">
        Most Bible apps make you <em>read</em>.<br/>
        Bible Blitz makes you <span class="accent-text">recall</span>.
      </p>
      <p class="premise-sub">
        Active recall is how knowledge sticks. Every round is short enough to do on a coffee
        break and structured so the verses you miss become the verses you remember.
      </p>
    </div>
  </section>

  <!-- WHAT YOU CAN DO ------------------------------------------------ -->
  <section class="features">
    <div class="container-narrow">
      <p class="eyebrow">What's inside</p>
      <h2>A small app that does a few things well.</h2>

      <div class="feat">
        <h3>Daily Challenge</h3>
        <p>A new 5-question round every day with bonus XP. Builds a streak you'll want to protect.</p>
      </div>
      <div class="feat">
        <h3>Categories</h3>
        <p>Ten hand-curated topics — Gospels, Pauline epistles, Old Testament narrative, Psalms, parables, miracles, and more — so you can focus where you want to grow.</p>
      </div>
      <div class="feat">
        <h3>Memorize</h3>
        <p>Step-by-step verse memorization. Words fade in stages until you can recite from memory.</p>
      </div>
      <div class="feat">
        <h3>Timed Blitz <span class="badge">Premium</span></h3>
        <p>Rapid-fire questions against the clock. For when you want pressure, not just practice.</p>
      </div>
      <div class="feat">
        <h3>Smart Review <span class="badge">Premium</span></h3>
        <p>Surfaces questions you previously missed. Spaced repetition without the overhead.</p>
      </div>
    </div>
  </section>

  <!-- PRICING -------------------------------------------------------- -->
  <section class="pricing">
    <div class="container-narrow">
      <p class="eyebrow">Pricing</p>
      <h2>Free to play. <span class="accent-text">$4.99</span> if you want more.</h2>
      <p class="pricing-sub">
        The core game is free forever — no ads, no nags, no expiring trial. The one-time $4.99
        unlock adds Timed Blitz and Smart Review. No subscription. Pay once or don't pay at all.
      </p>
      <a href={appStoreUrl} class="appstore-btn appstore-btn-light" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c0-2.05 1.68-3.04 1.76-3.09-.96-1.4-2.45-1.6-2.98-1.62-1.27-.13-2.48.75-3.12.75-.65 0-1.65-.74-2.72-.72-1.39.02-2.69.81-3.41 2.06-1.46 2.53-.37 6.26 1.04 8.31.69 1 1.5 2.13 2.57 2.09 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.68.64 1.11-.02 1.81-1.02 2.49-2.02.78-1.15 1.1-2.27 1.12-2.33-.02-.01-2.14-.82-2.16-3.27zM15.02 5.97c.56-.69.94-1.63.84-2.59-.81.04-1.81.54-2.39 1.22-.52.6-.98 1.57-.86 2.49.91.07 1.84-.46 2.41-1.12z"/></svg>
        <span><small>Download on the</small><strong>App Store</strong></span>
      </a>
    </div>
  </section>

  <!-- FAQ ------------------------------------------------------------ -->
  <section class="faq">
    <div class="container-narrow">
      <p class="eyebrow">Frequently asked</p>
      <h2>The short answers.</h2>
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FOOTER --------------------------------------------------------- -->
  <footer class="footer">
    <div class="container footer-inner">
      <div>
        <a href="/" class="brand brand-footer">
          <span class="brand-mark" aria-hidden="true">⛰</span>
          <span class="brand-name">Alpine Squad</span>
        </a>
        <p class="footer-tag">Small, focused apps for iOS.</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href={appStoreUrl} rel="noopener">App Store</a>
        <a href="/bibleblitz/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="mailto:hello@alpinesquad.com">Contact</a>
      </nav>
    </div>
    <div class="container footer-bottom">
      <small>© {new Date().getFullYear()} Alpine Squad. Bible Blitz is a trademark of Alpine Squad.</small>
    </div>
  </footer>
</BaseLayout>

<style>
  /* NAV ------------------------------------------------------------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 15, 12, 0.72);
    backdrop-filter: saturate(150%) blur(16px);
    -webkit-backdrop-filter: saturate(150%) blur(16px);
    border-bottom: 1px solid var(--border-on-dark);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink-on-dark);
    font-weight: 600;
    font-size: 16px;
  }
  .brand-mark { font-size: 18px; color: var(--accent-pop); }
  .nav-cta {
    background: var(--ink-on-dark);
    color: var(--ink);
    padding: 9px 18px;
    border-radius: var(--r-pill);
    font-size: 14px;
    font-weight: 600;
    transition: transform 0.15s, opacity 0.15s;
  }
  .nav-cta:hover { color: var(--ink); opacity: 0.92; transform: translateY(-1px); }

  /* HERO ------------------------------------------------------------ */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--bg-dark);
    color: var(--ink-on-dark);
    padding: 88px 0 96px;
  }
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .hero-glow {
    position: absolute;
    top: -10%;
    left: -15%;
    width: 80%;
    height: 90%;
    background: radial-gradient(circle at center, rgba(31, 169, 104, 0.32) 0%, transparent 60%);
    filter: blur(40px);
  }
  .hero-inner {
    position: relative;
    max-width: 880px;
  }
  @media (max-width: 880px) {
    .hero { padding: 64px 0 72px; }
  }
  .hero-icon {
    width: 84px;
    height: 84px;
    border-radius: 20px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
    margin-bottom: 24px;
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 7.2vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: var(--ink-on-dark);
    margin: 18px 0 28px;
    text-wrap: balance;
    max-width: 16ch;
  }
  .hero-accent {
    font-style: italic;
    background: linear-gradient(135deg, var(--accent-pop) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-on-dark-soft);
    max-width: 52ch;
    margin-bottom: 32px;
  }
  .hero-cta { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .hero-claims {
    font-size: 13.5px;
    color: var(--ink-on-dark-muted);
    letter-spacing: 0.2px;
  }

  /* APP STORE BUTTON ----------------------------------------------- */
  .appstore-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #000;
    color: #fff;
    padding: 11px 22px 11px 18px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.14);
    transition: transform 0.15s;
  }
  .appstore-btn:hover { color: #fff; transform: translateY(-1px); }
  .appstore-btn span { display: flex; flex-direction: column; line-height: 1.1; }
  .appstore-btn small { font-size: 10px; opacity: 0.85; letter-spacing: 0.3px; }
  .appstore-btn strong { font-size: 17px; font-weight: 600; letter-spacing: -0.2px; }
  .appstore-btn-light {
    margin-top: 28px;
    background: var(--ink);
    color: var(--ink-on-dark);
    border-color: transparent;
  }

  /* PREMISE -------------------------------------------------------- */
  .premise {
    padding: 96px 0;
    text-align: center;
    background: var(--bg);
    border-top: 1px solid var(--border);
  }
  .premise .eyebrow { margin-bottom: 24px; }
  .premise-line {
    font-family: var(--serif);
    font-size: clamp(32px, 4.4vw, 48px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 24px;
    text-wrap: balance;
  }
  .premise-line em { font-style: italic; color: var(--ink-soft); }
  .accent-text {
    color: var(--accent-warm);
    font-style: italic;
  }
  .premise-sub {
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 52ch;
    margin: 0 auto;
  }

  /* FEATURES ------------------------------------------------------- */
  .features {
    padding: 96px 0;
    background: var(--bg-deep);
    border-top: 1px solid var(--border);
  }
  .features .eyebrow { margin-bottom: 16px; }
  .features h2,
  .pricing h2,
  .faq h2 {
    font-family: var(--serif);
    font-size: clamp(30px, 3.6vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 48px;
    text-wrap: balance;
  }
  .feat {
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .feat:last-child { border-bottom: 1px solid var(--border); }
  .feat h3 {
    font-size: 19px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .feat p {
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .badge {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--accent-warm);
    background: rgba(31,169,104,0.10);
    padding: 3px 8px;
    border-radius: 999px;
  }

  /* PRICING -------------------------------------------------------- */
  .pricing {
    padding: 96px 0;
    background: var(--bg);
    border-top: 1px solid var(--border);
  }
  .pricing .eyebrow { margin-bottom: 16px; }
  .pricing-sub {
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 56ch;
    margin-bottom: 8px;
  }

  /* FAQ ------------------------------------------------------------ */
  .faq {
    padding: 96px 0 112px;
    background: var(--bg-deep);
    border-top: 1px solid var(--border);
  }
  .faq .eyebrow { margin-bottom: 16px; }
  .faq-item {
    border-top: 1px solid var(--border);
    padding: 20px 0;
  }
  .faq-item:last-child { border-bottom: 1px solid var(--border); }
  .faq-item summary {
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    font-size: 22px;
    color: var(--ink-muted);
    font-weight: 400;
    transition: transform 0.2s;
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p {
    margin-top: 12px;
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 64ch;
  }

  /* FOOTER --------------------------------------------------------- */
  .footer {
    background: var(--bg-dark);
    color: var(--ink-on-dark-soft);
    padding: 56px 0 24px;
    border-top: 1px solid var(--border-on-dark);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .brand-footer { color: var(--ink-on-dark); }
  .footer-tag {
    margin-top: 8px;
    font-size: 14px;
    color: var(--ink-on-dark-muted);
  }
  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: var(--ink-on-dark-soft);
    font-size: 14px;
  }
  .footer-links a:hover { color: var(--ink-on-dark); }
  .footer-bottom {
    padding-top: 20px;
    border-top: 1px solid var(--border-on-dark);
    color: var(--ink-on-dark-muted);
    font-size: 12.5px;
  }
</style>
