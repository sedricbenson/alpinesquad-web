---
import BaseLayout from './BaseLayout.astro';
import ProductNav from '../components/ProductNav.astro';
import ProductFooter from '../components/ProductFooter.astro';

/**
 * Shared shell for every app product page.
 *
 * One design system, one accent knob: each app passes its signature color and
 * the `.s-*` section classes pick it up via CSS vars. Pages are just SEO
 * frontmatter + content sections. `appStoreUrl` omitted = coming-soon app
 * (nav/footer show a badge instead of a store link).
 */
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  appName: string;
  appHref: string;
  /** iOS Smart App Banner id — omit for unreleased apps */
  appId?: string;
  /** Public App Store URL — omit for unreleased apps (renders Coming soon) */
  appStoreUrl?: string;
  accent: string;
  accentPop: string;
  accentDeep: string;
  navLinks?: { label: string; href: string }[];
  privacyPath: string;
  termsPath: string;
  contactEmail: string;
  trademark?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonical,
  schema,
  appName,
  appHref,
  appId,
  appStoreUrl,
  accent,
  accentPop,
  accentDeep,
  navLinks = [],
  privacyPath,
  termsPath,
  contactEmail,
  trademark,
} = Astro.props;
---

<BaseLayout {title} {description} {ogImage} {canonical} {schema} {appId}>
  <div
    class="app-shell"
    style={`--s-accent:${accent}; --s-accent-pop:${accentPop}; --s-accent-deep:${accentDeep};`}
  >
    <ProductNav {appName} {appHref} {appStoreUrl} links={navLinks} />

    <main>
      <slot />
    </main>

    <ProductFooter
      {appName}
      {appHref}
      {appStoreUrl}
      {privacyPath}
      {termsPath}
      {contactEmail}
      {trademark}
    />
  </div>
</BaseLayout>

<style is:global>
  .app-shell p a {
    color: var(--s-accent-deep);
    font-weight: 500;
  }
  .app-shell p a:hover {
    color: var(--s-accent);
  }

  /* HERO (light, accent-tinted) -------------------------------------- */
  .app-shell .s-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--s-accent) 9%, #ffffff) 0%,
      #ffffff 82%
    );
    color: var(--ink);
    padding: 88px 0 80px;
  }
  @media (max-width: 880px) {
    .app-shell .s-hero { padding: 64px 0 64px; }
  }
  .app-shell .s-hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .app-shell .s-hero-glow {
    position: absolute;
    top: -30%;
    left: -10%;
    width: 70%;
    height: 80%;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--s-accent) 16%, transparent) 0%,
      transparent 60%
    );
    filter: blur(48px);
  }
  .app-shell .s-hero-inner { position: relative; max-width: 880px; }
  .app-shell .s-hero-icon {
    width: 84px;
    height: 84px;
    border-radius: 20px;
    box-shadow: 0 10px 28px rgba(29, 29, 31, 0.18);
    margin-bottom: 24px;
  }
  .app-shell .s-eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--s-accent-deep);
    margin-bottom: 18px;
  }
  .app-shell .s-hero h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 7vw, 76px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
    max-width: 18ch;
  }
  .app-shell .s-hero-accent {
    font-style: italic;
    background: linear-gradient(135deg, var(--s-accent) 0%, var(--s-accent-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .app-shell .s-lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 56ch;
    margin-bottom: 32px;
  }
  .app-shell .s-hero-cta { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .app-shell .s-hero-claims {
    font-size: 13.5px;
    color: var(--ink-muted);
    letter-spacing: 0.2px;
  }

  /* TRUST ROW ------------------------------------------------------- */
  .app-shell .s-trust-row { display: flex; flex-wrap: wrap; gap: 10px 18px; margin-top: 28px; }
  .app-shell .s-trust-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13.5px;
    color: var(--ink-soft);
  }
  .app-shell .s-trust-chip svg {
    width: 15px;
    height: 15px;
    stroke: var(--s-accent);
    stroke-width: 2.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* STAT STRIP ------------------------------------------------------ */
  .app-shell .s-stat-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 44px;
    border-top: 1px solid var(--border);
    padding-top: 32px;
  }
  .app-shell .s-stat-value {
    font-family: var(--serif);
    font-size: 34px;
    font-weight: 600;
    color: var(--ink);
    display: block;
    line-height: 1;
  }
  .app-shell .s-stat-value .accent { color: var(--s-accent-deep); }
  .app-shell .s-stat-label { font-size: 13px; color: var(--ink-muted); margin-top: 8px; display: block; }
  @media (max-width: 640px) {
    .app-shell .s-stat-strip { grid-template-columns: repeat(2, 1fr); gap: 24px 20px; }
  }

  /* SECTIONS (light) ------------------------------------------------ */
  .app-shell .s-section { padding: 88px 0; background: var(--bg); border-top: 1px solid var(--border); }
  .app-shell .s-section-alt { padding: 88px 0; background: var(--bg-deep); border-top: 1px solid var(--border); }
  .app-shell .s-h2 {
    font-family: var(--serif);
    font-size: clamp(30px, 3.6vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 16px;
    text-wrap: balance;
  }
  .app-shell .s-section-lede {
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: 40px;
  }

  /* MODES / SPLIT CARDS --------------------------------------------- */
  .app-shell .s-modes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .app-shell .s-mode-card {
    padding: 32px;
    border-radius: var(--r-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
  }
  .app-shell .s-mode-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .app-shell .s-mode-icon svg {
    width: 24px;
    height: 24px;
    stroke: #fff;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .app-shell .s-mode-a .s-mode-icon { background: linear-gradient(135deg, var(--s-accent-pop), var(--s-accent)); }
  .app-shell .s-mode-b .s-mode-icon { background: linear-gradient(135deg, var(--ember, #ff7b47), #e0533a); }
  .app-shell .s-mode-card h3 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .app-shell .s-mode-card p { font-size: 15.5px; color: var(--ink-soft); line-height: 1.6; }

  /* FEATURES -------------------------------------------------------- */
  .app-shell .s-feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px 24px;
  }
  .app-shell .s-feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--s-accent) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .app-shell .s-feature-icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--s-accent);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .app-shell .s-feature h4 { font-size: 17px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
  .app-shell .s-feature p { font-size: 15px; color: var(--ink-soft); line-height: 1.55; }

  /* AUDIENCE CHIPS --------------------------------------------------- */
  .app-shell .s-audience-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .app-shell .s-chip {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 8px 16px;
    border-radius: var(--r-pill);
  }

  /* FAQ --------------------------------------------------------------- */
  .app-shell .s-faq { padding: 88px 0; background: var(--bg-deep); border-top: 1px solid var(--border); }
  .app-shell .s-faq-item { border-top: 1px solid var(--border); padding: 20px 0; }
  .app-shell .s-faq-item:last-child { border-bottom: 1px solid var(--border); }
  .app-shell .s-faq-item summary {
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .app-shell .s-faq-item summary::-webkit-details-marker { display: none; }
  .app-shell .s-faq-item summary::after {
    content: '+';
    font-size: 22px;
    color: var(--ink-muted);
    font-weight: 400;
    transition: transform 0.2s;
  }
  .app-shell .s-faq-item[open] summary::after { transform: rotate(45deg); }
  .app-shell .s-faq-item :is(p, ul) {
    margin-top: 12px;
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 68ch;
  }
  .app-shell .s-faq-item ul { padding-left: 20px; }
  .app-shell .s-faq-item li { margin: 4px 0; }

  /* FINAL CTA (accent gradient band) ---------------------------------- */
  .app-shell .s-final {
    padding: 96px 0;
    background: linear-gradient(135deg, var(--s-accent-deep) 0%, var(--s-accent) 100%);
    color: #fff;
    text-align: center;
  }
  .app-shell .s-final h2 {
    font-family: var(--serif);
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .app-shell .s-final p { font-size: 17px; color: rgba(255, 255, 255, 0.85); max-width: 48ch; margin: 0 auto 28px; }
  .app-shell .s-final p a { color: #fff; text-decoration: underline; }
  .app-shell .s-final .coming-soon-badge {
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
  }
  .app-shell .s-final .appstore-btn { margin: 0 auto; }
  .app-shell .s-final .coming-soon-badge { margin: 0 auto; }

  /* PRICING ----------------------------------------------------------- */
  .app-shell .s-price {
    font-family: var(--serif);
    font-size: clamp(38px, 5vw, 56px);
    font-weight: 600;
    color: var(--s-accent-deep);
    line-height: 1;
  }
  .app-shell .s-price-note { font-size: 15px; color: var(--ink-soft); margin-top: 10px; }
</style>
