---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  /** App Store id — drives the iOS Safari Smart App Banner. Omit on pages with no single app. */
  appId?: string;
  /** Mobile browser chrome color — match the top of the page (nav). */
  themeColor?: string;
  /** Optional theme override — 'dark' renders the page on the dark palette */
  theme?: 'auto' | 'dark' | 'light';
}

const {
  title,
  description,
  ogImage,
  canonical,
  schema,
  appId,
  themeColor = '#FBF7EE',
  theme = 'auto',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://alpinesquad.com';
const fullCanonical = canonical ?? `${site}${Astro.url.pathname}`;
const fullOgImage = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : `${site}${ogImage}`
  : undefined;
---

<!DOCTYPE html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content={themeColor} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    {fullOgImage && (
      <>
        <meta property="og:image" content={fullOgImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />
      </>
    )}
    <meta property="og:site_name" content="Alpine Squad" />

    <meta name="twitter:card" content={fullOgImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:url" content={fullCanonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {fullOgImage && <meta name="twitter:image" content={fullOgImage} />}
    {fullOgImage && <meta name="twitter:image:alt" content={title} />}

    {appId && <meta name="apple-itunes-app" content={`app-id=${appId}`} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/alpinesquad-icon.png" />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <style is:global>
      /* ============================
         Design tokens — Alpine Squad
         ============================ */
      :root {
        /* Brand */
        --accent: #1FA968;
        --accent-warm: #178A53;
        --accent-pop: #34D17F;
        --gold: #C9A961;
        --ember: #FF7B47;

        /* Backgrounds — light */
        --bg: #FBF7EE;
        --bg-elevated: #FFFFFF;
        --bg-deep: #F1EADA;

        /* Backgrounds — dark hero / sections */
        --bg-dark: #0A0F0C;
        --bg-dark-elevated: #131A14;
        --bg-dark-deep: #060B07;

        /* Ink */
        --ink: #0E1413;
        --ink-soft: #4A5050;
        --ink-muted: #8B9292;
        --ink-on-dark: #F4F1EA;
        --ink-on-dark-soft: #A8AFA5;
        --ink-on-dark-muted: #6C736A;

        /* Borders + shadow */
        --border: rgba(14, 20, 19, 0.08);
        --border-on-dark: rgba(244, 241, 234, 0.10);
        --shadow-sm: 0 1px 2px rgba(14, 20, 19, 0.04), 0 2px 6px rgba(14, 20, 19, 0.04);
        --shadow-md: 0 4px 12px rgba(14, 20, 19, 0.06), 0 12px 32px rgba(14, 20, 19, 0.08);
        --shadow-lg: 0 8px 24px rgba(14, 20, 19, 0.08), 0 32px 64px rgba(14, 20, 19, 0.12);
        --shadow-hero: 0 24px 80px rgba(31, 169, 104, 0.18), 0 12px 40px rgba(0, 0, 0, 0.32);

        /* Typography */
        --serif: ui-serif, 'New York', 'Iowan Old Style', 'Charter', 'Palatino', serif;
        --sans: -apple-system, BlinkMacSystemFont, 'Inter', 'SF Pro Display', 'Segoe UI', Helvetica, Arial, sans-serif;
        --mono: ui-monospaced, 'SF Mono', Menlo, Consolas, monospace;

        /* Radii */
        --r-sm: 8px;
        --r-md: 14px;
        --r-lg: 20px;
        --r-xl: 32px;
        --r-pill: 9999px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        font-family: var(--sans);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.55;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }

      img, svg, video { max-width: 100%; height: auto; display: block; }
      a { color: var(--accent-warm); text-decoration: none; transition: color 0.15s; }
      a:hover { color: var(--accent); }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .container-narrow {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* Typography utilities */
      .eyebrow {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--accent);
      }
      .eyebrow-on-dark {
        color: var(--accent-pop);
      }

      /* Scroll reveal — opt-in via .reveal */
      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.8s cubic-bezier(0.2, 0.7, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.7, 0.2, 1);
      }
      .reveal.is-in {
        opacity: 1;
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }
    </style>

    <script>
      // Lightweight scroll-reveal — adds .is-in when an element enters the
      // viewport. ~30 lines beats pulling in a 20kB lib.
      if (typeof window !== 'undefined' && 'IntersectionObserver' in window) {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                obs.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
